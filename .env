# ExMat AI Environment Variables

# GPU Configuration
CUDA_VISIBLE_DEVICES=0
CUDA_LAUNCH_BLOCKING=1

# Ollama Configuration (Docker)
OLLAMA_HOST=http://localhost:11434

# Model Paths (optional - will auto-download if not set)
# CHEMVLM_MODEL_PATH=/path/to/chemvlm
# MOLDET_MODEL_PATH=/path/to/moldet

# Processing
BATCH_SIZE=1
MAX_WORKERS=4

# Logging
LOG_LEVEL=INFO
DEBUG_MODE=false
